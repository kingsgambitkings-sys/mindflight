# MindForce Configuration
# Copy this to .env and fill in your values

# Server
PORT=3000

# Claude API (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Google OAuth2 (get from console.cloud.google.com)
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxx
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Twilio (get from twilio.com/console) - Optional for Phase 1
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=xxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=+1234567890

# Amadeus Flight API (get free keys from developers.amadeus.com)
AMADEUS_API_KEY=your-api-key
AMADEUS_API_SECRET=your-api-secret
AMADEUS_ENV=test

# Slack (get from api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# Jarvis Email Bridge
JARVIS_EMAIL=kinggambit@yourmindaddress.com

# Email sending (for Jarvis bridge - use Gmail App Password)
SMTP_USER=your@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
